{
  "version": "2.0.0",
  "tasks": [
    {
      "label": "ACM Run Python",
      "type": "shell",
      "command": "cls && python main.py < input.txt",
      "options": {
        "cwd": "${fileDirname}",
        "shell": {
          "executable": "C:\\Windows\\System32\\cmd.exe",
          "args": ["/d", "/c"]
        }
      },
      "presentation": {
        "reveal": "always",
        "focus": true,
        "panel": "dedicated",
        "clear": true
      },
      "problemMatcher": []
    }
  ]
}